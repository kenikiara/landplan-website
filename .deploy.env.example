# Copy this file to  .deploy.env  and fill in your cPanel FTP details.
# .deploy.env is git-ignored so your password is never committed.
#
# Find these in cPanel -> FTP Accounts (use your main account or a dedicated one).

FTP_HOST=ftp.landplan.co.ke
FTP_USER=your_ftp_user@landplan.co.ke
FTP_PASS=your_ftp_password
FTP_DIR=/public_html
# FTP_PROTO=ftps   # uncomment to force secure FTPS (recommended if your host supports it)
